{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-async-promise-executor": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["dist", "node_modules"]
}
